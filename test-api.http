@Base_url=http://localhost:8801/api

### GET /auth/me
GET {{Base_url}}/auth/me

### POST /auth/login
POST {{Base_url}}/auth/login

###
POST {{Base_url}}/auth/login HTTP/1.1
Content-Type: application/json

{
    "identity" : "andy@mail.com",
    "password" : "123457"
}

### 
POST {{Base_url}}/post HTTP/1.1
Content-Type: application/json

{
    "message": "sample"
}


### Register api POST/auth/register
POST {{Base_url}}/auth/register
Content-Type: application/json

{
    "email": "ammy3@mail.com",
    "password": "Ab123456",
    "confirmPassword": "Ab123456",
    "firstName": "ammy",
    "lastName": "codecamp",
    "mobile": "0812345671"
}